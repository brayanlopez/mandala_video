{
  "name": "mandala-animada",
  "version": "1.0.0",
  "description": "Animación de mandala con imágenes, exportable a video Full HD",
  "private": true,
  "dependencies": {
    "ccapture.js": "1.1.0",
    "p5": "1.9.4",
    "three": "0.128.0"
  },
  "scripts": {
    "dev": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint js/ config.js",
    "format:check": "prettier --check \"js/**/*.js\" config.js styles.css",
    "format:write": "prettier --write \"js/**/*.js\" config.js styles.css",
    "check": "npm run lint && npm run format:check && npm run test:coverage"
  },
  "engines": {
    "node": ">=16"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.0.0",
    "vitest": "^4.1.4"
  }
}
